
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    // --- Patient Records (Public Read for Search) ---
    match /patients/{patientId} {
      // Allow public read (get and list) for searching by ID/Name
      allow read: if true;
      
      allow create: if isSignedIn() && request.resource.data.addedByUserId == request.auth.uid;
      allow update: if isSignedIn() && resource != null && (resource.data.addedByUserId == request.auth.uid);
      allow delete: if isSignedIn() && resource != null && resource.data.addedByUserId == request.auth.uid;

      match /vitalsRecords/{vitalsRecordId} {
        allow read: if true; // Public check for trends if needed
        allow create: if isSignedIn() && request.resource.data.addedByUserId == request.auth.uid;
        allow update, delete: if isSignedIn() && resource != null && (resource.data.addedByUserId == request.auth.uid);
      }

      match /clinicalNotes/{clinicalNoteId} {
        allow read, write: if isSignedIn(); // Keep notes private to medical staff
      }

      match /predictions/{predictionId} {
        allow read: if true; // Public check for results
        allow create: if isSignedIn() && request.resource.data.triggeredByUserId == request.auth.uid;
        allow update, delete: if isSignedIn() && resource != null && (resource.data.triggeredByUserId == request.auth.uid);
      }
    }
  }
}
